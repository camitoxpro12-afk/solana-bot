# ================================================================
# SOLANA BOT - CONFIGURACION
# Copia este archivo como .env y rellena los valores
# ================================================================

# Tu clave privada de Phantom (Settings > Security > Export Private Key)
# NUNCA compartas esta clave con nadie. DEJALA VACIA para modo simulacion (paper).
PRIVATE_KEY=

# RPC de Solana (el publico funciona, Helius es mas rapido)
# Gratis en: https://helius.dev (1M requests/mes gratis)
RPC_URL=https://api.mainnet-beta.solana.com

# === PARAMETROS DE TRADING ===
MAX_TRADE_PCT=0.18          # Maximo % del balance por operacion (18%)
MIN_TRADE_SOL=0.02          # Minimo SOL por trade
TAKE_PROFIT_PCT=1.5         # 150% de ganancia = vender al 2.5x
STOP_LOSS_PCT=0.35          # Parar perdidas al -35%
MAX_POSITIONS=3             # Maximo de posiciones abiertas a la vez
SLIPPAGE_BPS=500            # Slippage 5% (500 puntos base)

# === FILTROS DE TOKENS ===
MIN_LIQUIDITY_USD=4000      # Liquidez minima en dolares
MIN_SCORE=62                # Puntuacion minima para comprar (0-100)
MAX_TOP10_PCT=45            # Maxima concentracion top10 wallets
MIN_TOKEN_AGE_MINUTES=20    # No comprar tokens de menos de 20 min
MAX_TOKEN_AGE_HOURS=48      # No comprar tokens de mas de 48h

# === APIS OPCIONALES (mejoran el analisis) ===
# CryptoPanic (noticias): https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_KEY=

# Birdeye (datos on-chain): https://birdeye.so/
BIRDEYE_API_KEY=

# === CAPA DE RAZONAMIENTO LLM (Claude) ===
# Segundo filtro: Claude razona sobre cada candidato antes de comprar.
# Consigue tu API key en: https://console.anthropic.com/
ANTHROPIC_API_KEY=
ENABLE_LLM_REVIEW=true        # false = solo analisis algoritmico (sin coste LLM)
# Modelo: claude-haiku-4-5 (barato) | claude-sonnet-4-6 (equilibrado) | claude-opus-4-8 (el mas listo, mas caro)
LLM_MODEL=claude-sonnet-4-6
LLM_MIN_CONFIDENCE=55         # si el LLM dice 'buy' con menos confianza, se omite
ENABLE_LLM_THINKING=true      # razonamiento profundo (mas listo, ~3x coste). false = mas barato
# Busqueda web: Claude investiga reputacion/rugs/sentimiento. Mas informado pero
# +lento y +coste (~$0.01 por busqueda). Recomendado con sonnet/opus, no haiku.
ENABLE_LLM_WEBSEARCH=false
# IA GRATIS de respaldo (Google Gemini): se usa si Claude falla o se acaba el saldo.
# Key gratis en https://aistudio.google.com/apikey  (puedes usar SOLO esto y dejar ANTHROPIC vacio = IA gratis)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# === ESTRATEGIA DE SALIDA AVANZADA ===
# Take-profit parcial: vende parte al llegar a Nx para recuperar tu capital
ENABLE_PARTIAL_TP=true
PARTIAL_TP_TRIGGER_PCT=1.0      # +100% = 2x (ganancia a la que vende parte)
PARTIAL_TP_SELL_FRACTION=0.5    # vende la mitad
# Trailing stop: el stop sube con el precio (captura pumps grandes).
# Si esta en true, sustituye al take-profit fijo y deja correr al ganador.
ENABLE_TRAILING_STOP=true
TRAILING_STOP_PCT=0.30          # vende si cae 30% desde el pico
# Anti-honeypot: simula compra+venta (via Jupiter) antes de comprar de verdad
ENABLE_HONEYPOT_CHECK=true
HONEYPOT_MAX_ROUNDTRIP_LOSS_PCT=0.30
# Analisis dev/bundle: marca concentracion del creador / insiders
ENABLE_DEV_ANALYSIS=true
MAX_CREATOR_PCT=15

# === SWING TRADING DE SOL (rotar SOL <-> USDC segun el mercado) ===
# Mantiene SOL cuando el mercado esta alcista; lo protege en USDC cuando esta bajista.
ENABLE_SOL_SWING=true
SOL_SWING_PCT=0.3             # % del balance dedicado al swing de SOL
SOL_SWING_ENTER_SCORE=55     # vuelve a SOL si la senal del mercado >= (0-100)
SOL_SWING_EXIT_SCORE=35      # protege en USDC si la senal del mercado <=
SOL_SWING_INTERVAL=600       # revisa cada 600s (10 min)

# === SEGURIDAD ===
MAX_DAILY_LOSS_PCT=0.25     # Parar bot si pierde 25% en un dia
# IMPORTANTE: empieza SIEMPRE en false (simulacion). Cambia a true solo cuando
# quieras operar con dinero real (y desde el dashboard con la wallet configurada).
ENABLE_TRADING=false
